generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Client {
  id              String        @id @default(cuid())
  name            String
  email           String?
  phone           String?
  address         String?
  notes           String?
  source          String?
  clientType      String?
  preferredStyle  String?
  avoidedColors   String?
  floralAllergies String?
  usualBudget     Float?
  isVip           Boolean       @default(false)
  events          Event[]
  photos          ClientPhoto[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model ClientPhoto {
  id        String   @id @default(cuid())
  url       String
  clientId  String
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Event {
  id          String  @id @default(cuid())
  name        String
  clientId    String?
  client      Client? @relation(fields: [clientId], references: [id])
  date        DateTime
  address     String?
  phone       String?
  budget      Float?
  description String?
  status      String  @default("DEVIS_EN_COURS")
  type        String?
  style       String?
  theme       String?
  colorPalette String?
  isOutdoor   Boolean @default(false)
  guestCount  Int?
  roundTables Int?
  rectTables  Int?
  squareTables Int?
  centerpieces Int?
  ceremonyCompositions Int?
  roomWidth   Float?
  roomLength  Float?
  roomHeight  Float?
  setupStartTime   DateTime?
  setupEndTime     DateTime?
  dismantlingTime  DateTime?
  weddingPlannerName  String?
  weddingPlannerPhone String?
  catererName      String?
  photographerName String?
  onSiteContactName  String?
  onSiteContactPhone String?
  floorPlanUrl     String?

  reservations     Reservation[]
  logistics        Logistics?
  previews         Preview[]
  gallery          MediaItem[]
  documents        Document[]
  costs            EventCost?
  checklist        ChecklistItem[]
  freshFlowers     FreshFlowerOrder[]
  timeline         EventTimeline[]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model StockCategory {
  id            String            @id @default(cuid())
  name          String
  subCategories StockSubCategory[]
  items         StockItem[]
}

model StockSubCategory {
  id         String        @id @default(cuid())
  name       String
  categoryId String
  category   StockCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  items      StockItem[]
}

model StockItem {
  id              String            @id @default(cuid())
  name            String
  categoryId      String?
  category        StockCategory?    @relation(fields: [categoryId], references: [id])
  subCategoryId   String?
  subCategory     StockSubCategory? @relation(fields: [subCategoryId], references: [id])
  color           String?
  description     String?
  totalQuantity   Int               @default(0)
  purchasePrice   Float?
  storageLocation String?
  condition       String            @default("BON_ETAT")
  notes           String?
  material        String?
  dimensions      String?
  weight          Float?
  capacity        String?
  shape           String?
  isFoldable      Boolean   @default(false)
  pieces          Int?
  species         String?
  stemLength      Float?
  archShape       String?
  assemblyTime    Int?
  candleType      String?
  burnTime        Int?

  photos          StockPhoto[]
  reservations    Reservation[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model StockPhoto {
  id          String    @id @default(cuid())
  url         String
  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model Reservation {
  id          String    @id @default(cuid())
  eventId     String
  event       Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  stockItemId String
  stockItem   StockItem @relation(fields: [stockItemId], references: [id])
  quantity    Int
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Transporter {
  id        String             @id @default(cuid())
  name      String
  phone     String?
  email     String?
  notes     String?
  logistics Logistics[]
  photos    TransporterPhoto[]
  createdAt DateTime           @default(now())
}

model TransporterPhoto {
  id            String      @id @default(cuid())
  url           String
  transporterId String
  transporter   Transporter @relation(fields: [transporterId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
}

model Logistics {
  id               String       @id @default(cuid())
  eventId          String       @unique
  event            Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  transporterId    String?
  transporter      Transporter? @relation(fields: [transporterId], references: [id])
  pickupDate       DateTime?
  deliveryDate     DateTime?
  returnDate       DateTime?
  status           String?
  vehicleType      String?
  tripsCount       Int?
  estimatedVolume  String?
  departureAddress String?
  loadingNotes     String?
  hasFragileItems  Boolean      @default(false)
  notes            String?
  documents        LogisticsDocument[]
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
}

model LogisticsDocument {
  id          String    @id @default(cuid())
  url         String
  name        String
  logisticsId String
  logistics   Logistics @relation(fields: [logisticsId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
}

model Preview {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url       String
  type      String   @default("MOODBOARD")
  status    String   @default("BROUILLON")
  zone      String?
  version   Int      @default(1)
  clientFeedback String?
  notes     String?
  createdAt DateTime @default(now())
}

model MediaItem {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url       String
  type      String
  isReel    Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
}

model Document {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url       String
  name      String
  type      String   @default("AUTRE")
  createdAt DateTime @default(now())
}

model EventCost {
  id               String   @id @default(cuid())
  eventId          String   @unique
  event            Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  flowers          Float    @default(0)
  freshFlowersCost Float    @default(0)
  materials        Float    @default(0)
  labor            Float    @default(0)
  delivery         Float    @default(0)
  subcontracting   Float    @default(0)
  misc             Float    @default(0)
  postEventCosts   Float    @default(0)
  invoicedPrice    Float    @default(0)
  deposit          Float    @default(0)
  depositDate      DateTime?
  balanceDueDate   DateTime?
  paymentMethod    String?
  discount         Float    @default(0)
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ChecklistItem {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  label     String
  done      Boolean  @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model FreshFlowerOrder {
  id           String    @id @default(cuid())
  eventId      String
  event        Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id])
  species      String
  quantity     Int
  unit         String    @default("tiges")
  unitPrice    Float?
  orderDate    DateTime?
  deliveryDate DateTime?
  received     Boolean   @default(false)
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Supplier {
  id           String             @id @default(cuid())
  name         String
  phone        String?
  email        String?
  address      String?
  specialty    String?
  notes        String?
  freshFlowers FreshFlowerOrder[]
  photos       SupplierPhoto[]
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
}

model SupplierPhoto {
  id         String   @id @default(cuid())
  url        String
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model FloralRecipe {
  id            String             @id @default(cuid())
  name          String
  description   String?
  prepTime      Int?
  estimatedCost Float?
  ingredients   FloralIngredient[]
  photos        RecipePhoto[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model RecipePhoto {
  id        String       @id @default(cuid())
  url       String
  recipeId  String
  recipe    FloralRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now())
}

model FloralIngredient {
  id        String       @id @default(cuid())
  recipeId  String
  recipe    FloralRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  name      String
  quantity  Int
  unit      String       @default("tiges")
  notes     String?
}

model EventTemplate {
  id          String                  @id @default(cuid())
  name        String
  type        String?
  style       String?
  description String?
  checklist   TemplateChecklistItem[]
  photos      TemplatePhoto[]
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
}

model TemplatePhoto {
  id         String        @id @default(cuid())
  url        String
  templateId String
  template   EventTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  createdAt  DateTime      @default(now())
}

model TemplateChecklistItem {
  id         String        @id @default(cuid())
  templateId String
  template   EventTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  label      String
  order      Int           @default(0)
}

model EventTimeline {
  id        String   @id @default(cuid())
  eventId   String
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  action    String
  details   String?
  automatic Boolean  @default(false)
  createdAt DateTime @default(now())
}
